{
  "name": "stx402-agent",
  "version": "3.0.0",
  "description": "Remote MCP server for Stacks blockchain & x402 payments - works with Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "stx402-agent": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "server": "bun run src/server.ts",
    "server:dev": "bun --watch run src/server.ts",
    "docker:build": "docker build -t stx402-agent .",
    "docker:run": "docker run -p 3000:3000 -v stx402-data:/data stx402-agent",
    "docker:compose": "docker-compose up",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "model-context-protocol",
    "x402",
    "stacks",
    "blockchain",
    "crypto",
    "payments",
    "remote-mcp"
  ],
  "author": "biwas",
  "repository": {
    "type": "git",
    "url": "https://github.com/biwasxyz/stx402-agent.git"
  },
  "homepage": "https://github.com/biwasxyz/stx402-agent#readme",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@scure/bip39": "^2.0.1",
    "@stacks/network": "^7.3.1",
    "@stacks/transactions": "^7.3.1",
    "@stacks/wallet-sdk": "^7.2.0",
    "alex-sdk": "^3.2.1",
    "axios": "^1.13.2",
    "dotenv": "^17.2.3",
    "x402-stacks": "^1.1.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}

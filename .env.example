# stx402-agent Environment Configuration
# Copy this to .env and customize as needed

# =============================================================================
# Server Configuration (Remote Mode)
# =============================================================================

# Port to run the server on (default: 3000)
PORT=3000

# Host to bind to (default: 0.0.0.0 for all interfaces)
HOST=0.0.0.0

# =============================================================================
# Stacks Network Configuration
# =============================================================================

# Network: mainnet or testnet (default: testnet)
NETWORK=testnet

# x402 API base URL (default: https://x402.biwas.xyz)
API_URL=https://x402.biwas.xyz

# =============================================================================
# Storage Configuration (Remote Server Mode)
# =============================================================================

# Base directory for user data (default: /data in Docker, ~/.stx402-server otherwise)
# DATA_DIR=/data

# Set to "true" when running in Docker (auto-sets DATA_DIR=/data)
# DOCKER=true

# =============================================================================
# Optional: Default Wallet (Local Mode / Fallback)
# =============================================================================

# 24-word BIP39 mnemonic for default wallet (optional)
# If set, provides a fallback wallet when no user wallet is available
# CLIENT_MNEMONIC="your twenty four word mnemonic phrase goes here"
